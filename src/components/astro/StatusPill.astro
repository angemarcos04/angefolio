---
import Tag from './Tag.astro';
interface Props {
  status: string;
  class?: string;
}
const { status, class: className = '' } = Astro.props;
const normalized = status.toLowerCase();
const tone =
  normalized === 'live' || normalized === 'in progress'
    ? 'green'
    : normalized === 'prototype' || normalized === 'testing'
      ? 'cyan'
      : normalized === 'planning' || normalized === 'idea'
        ? 'purple'
        : normalized === 'paused'
          ? 'yellow'
          : 'neutral';
---

<Tag {tone} class={className}>{status}</Tag>
