---
import { site } from '../../lib/data/site';
import IconLink from './IconLink.astro';
---

<footer class="container-shell">
  <p>Built by {site.name}. <span>Astro-first, terminal at heart.</span></p>
  <nav aria-label="Footer navigation">
    <IconLink href="/search" label="Search" />
    <IconLink href={site.rss} label="RSS" />
    <IconLink href={site.github} label="GitHub" external />
  </nav>
</footer>
<style>
  footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.4rem 2.5rem;
    border-top: 1px solid var(--border);
    color: var(--muted-foreground);
    font: 0.875rem/1.6 var(--type-body);
  }
  footer p {
    margin: 0;
  }
  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }
  @media (max-width: 540px) {
    footer {
      align-items: flex-start;
      flex-direction: column;
    }
    footer span {
      display: block;
      margin-top: 0.25rem;
    }
  }
</style>
