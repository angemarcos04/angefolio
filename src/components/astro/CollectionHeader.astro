---
import BrandLogo from './BrandLogo.astro';
import ThemeToggle from '../svelte/ThemeToggle.svelte';

interface Props {
  active?: 'projects' | 'notes' | 'lab' | 'search';
}

const { active } = Astro.props;
const navItems = [
  { label: 'Projects', href: '/projects', key: 'projects' },
  { label: 'Notes', href: '/notes', key: 'notes' },
  { label: 'Lab', href: '/lab', key: 'lab' },
  { label: 'Search', href: '/search', key: 'search' },
] as const;
---

<header class="collection-topbar" data-pagefind-ignore>
  <BrandLogo href="/" placement="header" priority />
  <div class="topbar-actions">
    <nav aria-label="Primary navigation">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            aria-current={active === item.key ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <ThemeToggle client:load />
  </div>
</header>

<style>
  .collection-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: clamp(2rem, 7vw, 4.5rem);
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--border);
  }
  .topbar-actions,
  nav {
    display: flex;
    align-items: center;
  }
  .topbar-actions {
    gap: 0.8rem;
  }
  nav {
    flex-wrap: wrap;
    gap: 0.2rem;
  }
  nav a {
    padding: 0.45rem 0.55rem;
    color: var(--muted-foreground);
    font: 0.72rem var(--font-mono);
  }
  nav a:hover,
  nav a[aria-current='page'] {
    color: var(--accent-text);
  }
  nav a[aria-current='page']::before {
    color: var(--accent);
    content: './';
  }
  @media (max-width: 540px) {
    .collection-topbar {
      align-items: stretch;
      flex-direction: column;
    }
    .topbar-actions {
      align-items: flex-start;
      flex-wrap: wrap;
      justify-content: space-between;
    }
    nav a {
      padding-inline: 0.4rem;
    }
  }
</style>
