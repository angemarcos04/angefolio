---
interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  description?: string;
  headingLevel?: 1 | 2;
  class?: string;
}
const {
  id,
  eyebrow,
  title,
  description,
  headingLevel = 2,
  class: className = '',
} = Astro.props;
---

<header class:list={['section-header', className]}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  {
    headingLevel === 1 ? (
      <h1 {id} class="text-balance">
        {title}
      </h1>
    ) : (
      <h2 {id} class="text-balance">
        {title}
      </h2>
    )
  }
  {description && <p>{description}</p>}
</header>
<style>
  .section-header {
    max-width: 48rem;
    margin-bottom: clamp(1rem, 3vw, 1.5rem);
  }
  .eyebrow {
    margin: 0 0 0.35rem;
  }
  :is(h1, h2) {
    margin: 0;
    font-size: clamp(1.6rem, 4vw, 2.35rem);
    line-height: 1.12;
    letter-spacing: -0.04em;
  }
  .section-header > p:last-child {
    margin: 0.65rem 0 0;
    color: var(--muted-foreground);
  }
</style>
