---
import StatusPill from './StatusPill.astro';
import Tag from './Tag.astro';
interface Props {
  title: string;
  description: string;
  status: string;
  tags: string[];
  date: Date | string;
  href?: string;
  class?: string;
}
const {
  title,
  description,
  status,
  tags,
  date,
  href,
  class: className = '',
} = Astro.props;
const formatted = new Intl.DateTimeFormat('en', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
  timeZone: 'UTC',
}).format(new Date(date));
---

<article class:list={['content-card bento-surface', className]}>
  <StatusPill {status} /><h3>{href ? <a href={href}>{title}</a> : title}</h3><p>
    {description}
  </p>
  <div>{tags.map((tag) => <Tag>{tag}</Tag>)}</div><small>{formatted}</small>
</article>
<style>
  .content-card {
    min-width: 0;
    padding: 1.25rem;
  }
  h3 {
    margin: 1rem 0 0;
    font-size: 1.1rem;
  }
  h3 a:hover {
    color: var(--accent-cyan);
  }
  p {
    margin: 0.45rem 0 1rem;
    color: var(--muted-foreground);
    font-size: 0.9rem;
  }
  div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  small {
    display: block;
    margin-top: 1rem;
    color: var(--muted-foreground);
    font: 0.65rem var(--font-mono);
  }
</style>
