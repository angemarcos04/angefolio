---
interface Props {
  id?: string;
  title?: string;
  eyebrow?: string;
  description?: string;
  class?: string;
  accent?: 'green' | 'cyan' | 'red' | 'purple' | 'yellow' | 'neutral';
}
const {
  id,
  title,
  eyebrow,
  description,
  class: className = '',
  accent = 'neutral',
} = Astro.props;
---

<section
  {id}
  class:list={['bento-card bento-surface', `accent-${accent}`, className]}
>
  {
    (eyebrow || title || description) && (
      <header>
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        {title && <h2>{title}</h2>}
        {description && <p class="card-description">{description}</p>}
      </header>
    )
  }
  <slot />
</section>
<style>
  .bento-card {
    --card-accent: var(--border);
    position: relative;
    min-width: 0;
    padding: clamp(1.15rem, 3vw, 1.75rem);
    overflow: hidden;
  }
  .bento-card::before {
    position: absolute;
    inset: 0 auto 0 0;
    width: 2px;
    background: var(--card-accent);
    content: '';
    opacity: 0.72;
  }
  .accent-green {
    --card-accent: var(--accent-green);
  }
  .accent-cyan {
    --card-accent: var(--accent-cyan);
  }
  .accent-red {
    --card-accent: var(--accent-red);
  }
  .accent-purple {
    --card-accent: var(--accent-purple);
  }
  .accent-yellow {
    --card-accent: var(--accent-yellow);
  }
  header {
    margin-bottom: 1rem;
  }
  header .eyebrow {
    margin: 0 0 0.35rem;
  }
  h2 {
    margin: 0;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.25;
    letter-spacing: -0.025em;
  }
  .card-description {
    max-width: 62ch;
    margin: 0.55rem 0 0;
    color: var(--muted-foreground);
    font-size: 0.92rem;
  }
</style>
