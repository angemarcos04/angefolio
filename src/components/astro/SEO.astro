---
import { site } from '../../lib/data/site';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string | URL;
  noindex?: boolean;
}
const {
  title,
  description,
  image = site.socialImage,
  type = 'website',
  canonical,
  noindex = false,
} = Astro.props;
const baseUrl = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = canonical
  ? new URL(canonical, baseUrl)
  : Astro.site
    ? new URL(Astro.url.pathname, Astro.site)
    : undefined;
const socialImage = image ? new URL(image, baseUrl) : undefined;
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="author" content={site.name} />
<meta name="theme-color" content="#2b2118" />
{noindex ? <meta name="robots" content="noindex, nofollow" /> : null}
{canonicalUrl ? <link rel="canonical" href={canonicalUrl} /> : null}
<link
  rel="alternate"
  type="application/rss+xml"
  title="angefolio notes"
  href={new URL(site.rss, baseUrl)}
/>
<meta property="og:type" content={type} />
<meta property="og:site_name" content={site.siteName} />
<meta property="og:locale" content="en_US" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{canonicalUrl ? <meta property="og:url" content={canonicalUrl} /> : null}
{socialImage ? <meta property="og:image" content={socialImage} /> : null}
{socialImage ? <meta property="og:image:type" content="image/png" /> : null}
{socialImage ? <meta property="og:image:width" content="1728" /> : null}
{socialImage ? <meta property="og:image:height" content="903" /> : null}
{
  socialImage ? (
    <meta
      property="og:image:alt"
      content="angefolio — Angellie Marcos, IT student, full-stack developer, and Linux user"
    />
  ) : null
}
<meta
  name="twitter:card"
  content={socialImage ? 'summary_large_image' : 'summary'}
/>
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{socialImage ? <meta name="twitter:image" content={socialImage} /> : null}
{
  socialImage ? (
    <meta
      name="twitter:image:alt"
      content="angefolio — Angellie Marcos, IT student, full-stack developer, and Linux user"
    />
  ) : null
}
