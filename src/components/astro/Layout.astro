---
import '../../styles/global.css';
import { site } from '../../lib/data/site';
import Footer from './Footer.astro';
import PageRail from './PageRail.astro';
import SEO from './SEO.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string | URL;
  noindex?: boolean;
  searchable?: boolean;
  showPageRail?: boolean;
  class?: string;
}

const {
  title = site.defaultTitle,
  description = site.seoDescription,
  image,
  type = 'website',
  canonical,
  noindex = false,
  searchable = true,
  showPageRail = true,
  class: className = '',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <SEO {title} {description} {image} {type} {canonical} {noindex} />
    <script is:inline>
      (() => {
        const validThemes = ['light', 'dim', 'dark'];
        const themeColors = {
          light: '#f7f3e3',
          dim: '#1b2430',
          dark: '#080b10',
        };
        let theme = 'dark';
        try {
          const savedTheme = localStorage.getItem('theme');
          if (savedTheme && validThemes.includes(savedTheme))
            theme = savedTheme;
        } catch {}
        document.documentElement.dataset.theme = theme;
        document
          .querySelector('meta[name="theme-color"]')
          ?.setAttribute('content', themeColors[theme]);
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    {showPageRail && <PageRail />}
    <main
      id="main-content"
      class:list={['container-shell', className]}
      tabindex="-1"
      data-pagefind-body={searchable ? true : undefined}
      data-pagefind-ignore={searchable ? undefined : true}
    >
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    padding-block: clamp(1.5rem, 6vw, 4.5rem);
  }
  .skip-link {
    position: fixed;
    z-index: 100;
    top: 0.75rem;
    left: 0.75rem;
    transform: translateY(-180%);
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    background: var(--card);
    color: var(--foreground);
    font: 0.78rem var(--font-mono);
  }
  .skip-link:focus {
    transform: translateY(0);
  }
</style>
