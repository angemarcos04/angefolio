---
interface Props {
  href?: string;
  placement?: 'header' | 'footer' | 'standalone';
  class?: string;
  priority?: boolean;
}

const {
  href,
  placement = 'standalone',
  class: className,
  priority = false,
} = Astro.props;

const imageAttributes = {
  width: 690,
  height: 250,
  loading: priority ? 'eager' : 'lazy',
  decoding: 'async',
  fetchpriority: priority ? 'high' : 'auto',
} as const;
---

{
  href ? (
    <a
      href={href}
      class:list={['brand-logo', `brand-logo--${placement}`, className]}
      aria-label="Angefolio home"
    >
      <span class="logo-frame" aria-hidden="true">
        <img
          {...imageAttributes}
          class="logo-image logo-light"
          src="/angefolio_logo_dropcap_light.svg"
          alt=""
        />
        <img
          {...imageAttributes}
          class="logo-image logo-dark"
          src="/angefolio_logo_dropcap_dark.svg"
          alt=""
        />
      </span>
    </a>
  ) : (
    <span
      class:list={['brand-logo', `brand-logo--${placement}`, className]}
      role="img"
      aria-label="Angefolio"
    >
      <span class="logo-frame" aria-hidden="true">
        <img
          {...imageAttributes}
          class="logo-image logo-light"
          src="/angefolio_logo_dropcap_light.svg"
          alt=""
        />
        <img
          {...imageAttributes}
          class="logo-image logo-dark"
          src="/angefolio_logo_dropcap_dark.svg"
          alt=""
        />
      </span>
    </span>
  )
}

<style>
  .brand-logo {
    display: inline-flex;
    min-height: 44px;
    max-width: 100%;
    align-items: center;
    justify-content: flex-start;
    flex-shrink: 0;
    border-radius: var(--radius-sm);
  }
  .brand-logo:focus-visible {
    outline: 3px solid var(--focus-ring);
    outline-offset: 4px;
  }
  .logo-frame {
    display: grid;
    width: 100%;
    aspect-ratio: 690 / 250;
  }
  .logo-image {
    grid-area: 1 / 1;
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
  }
  .logo-light {
    display: none;
  }
  .logo-dark {
    display: block;
  }
  :global(html[data-theme='light']) .logo-light {
    display: block;
  }
  :global(html[data-theme='light']) .logo-dark {
    display: none;
  }
  :global(html[data-theme='dim']) .logo-light,
  :global(html[data-theme='dark']) .logo-light {
    display: none;
  }
  :global(html[data-theme='dim']) .logo-dark,
  :global(html[data-theme='dark']) .logo-dark {
    display: block;
  }
  .brand-logo--header .logo-frame {
    width: clamp(10.5rem, 15vw, 12rem);
  }
  .brand-logo--footer .logo-frame {
    width: clamp(12rem, 24vw, 15rem);
  }
  .brand-logo--standalone .logo-frame {
    width: clamp(10.5rem, 50vw, 12rem);
  }
  @media (max-width: 480px) {
    .brand-logo--header .logo-frame {
      width: clamp(9rem, 44vw, 10.5rem);
    }
  }
</style>
