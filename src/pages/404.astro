---
import Button from '../components/astro/Button.astro';
import CollectionHeader from '../components/astro/CollectionHeader.astro';
import Layout from '../components/astro/Layout.astro';

export const prerender = true;
---

<Layout
  title="404 — Page not found — Angellie Marcos"
  description="The requested angefolio page could not be found."
  noindex
  searchable={false}
  class="not-found-page"
>
  <CollectionHeader />
  <section
    class="not-found bento-surface subtle-grid"
    aria-labelledby="not-found-title"
  >
    <p class="eyebrow">error / 404</p>
    <h1 id="not-found-title">That path does not exist.</h1>
    <p>
      The page may have moved, the experiment may have been archived, or the
      command was typed into the wrong terminal.
    </p>
    <div>
      <Button href="/" variant="primary">Return home</Button>
      <Button href="/search">Search the archive</Button>
    </div>
  </section>
</Layout>

<style>
  .not-found {
    padding: clamp(1.5rem, 7vw, 4rem);
    box-shadow: none;
  }
  .not-found .eyebrow {
    margin: 0 0 0.5rem;
  }
  h1 {
    max-width: 16ch;
    margin: 0;
    font-size: clamp(2.3rem, 8vw, 5rem);
    line-height: 0.98;
    letter-spacing: 0.02em;
  }
  .not-found > p:not(.eyebrow) {
    max-width: 58ch;
    margin: 1rem 0 1.4rem;
    color: var(--muted-foreground);
  }
  .not-found div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }
</style>
