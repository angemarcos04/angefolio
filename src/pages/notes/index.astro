---
import CardGrid from '../../components/astro/CardGrid.astro';
import CollectionHeader from '../../components/astro/CollectionHeader.astro';
import Layout from '../../components/astro/Layout.astro';
import NoteCard from '../../components/astro/NoteCard.astro';
import SectionHeader from '../../components/astro/SectionHeader.astro';
import Tag from '../../components/astro/Tag.astro';
import { getPublishedNotes } from '../../lib/content';
import { getAllCategories, getAllTags, getNoteUrl } from '../../lib/notes';

export const prerender = true;

const description =
  'Project logs, Linux fixes, web development notes, and thoughts from building things.';
const notes = await getPublishedNotes();
const categories = getAllCategories(notes);
const tags = getAllTags(notes);
---

<Layout title="Notes — Angellie Marcos" {description}>
  <CollectionHeader active="notes" />
  <section aria-labelledby="notes-title">
    <SectionHeader
      id="notes-title"
      eyebrow="/notes"
      title="Notes"
      {description}
      headingLevel={1}
      class="page-heading"
    />
    <div class="collection-summary">
      <p>
        This is where I document what I am learning, breaking, fixing, and
        slowly understanding.
      </p>
      <span>{notes.length} published</span>
    </div>
    {
      notes.length > 0 && (
        <aside
          class="archive-map bento-surface"
          aria-label="Notes archive topics"
        >
          <div>
            <strong>Categories</strong>
            <p>{categories.join(', ')}</p>
          </div>
          <div>
            <strong>Tags</strong>
            <div class="archive-tags">
              {tags.map((tag) => (
                <Tag>{tag}</Tag>
              ))}
            </div>
          </div>
        </aside>
      )
    }
    {
      notes.length > 0 ? (
        <CardGrid class="collection-grid">
          {notes.map((note) => (
            <NoteCard
              href={getNoteUrl(note)}
              title={note.data.title}
              description={note.data.summary ?? note.data.description}
              category={note.data.category}
              tags={note.data.tags}
              createdAt={note.data.createdAt}
              updatedAt={note.data.updatedAt}
              featured={note.data.featured}
            />
          ))}
        </CardGrid>
      ) : (
        <p class="empty-state">No published notes yet.</p>
      )
    }
  </section>
</Layout>

<style>
  :global(.page-heading) {
    margin-bottom: 1rem;
  }
  .collection-summary {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-block: 0.75rem;
    border-block: 1px solid var(--border);
  }
  .collection-summary p,
  .collection-summary span {
    margin: 0;
    color: var(--muted-foreground);
    font: 0.72rem/1.5 var(--font-mono);
  }
  .collection-summary p {
    max-width: 67ch;
  }
  .collection-summary span {
    flex: none;
    color: var(--accent-text);
  }
  :global(.collection-grid .content-card) {
    height: 100%;
    border-radius: var(--radius-md);
    box-shadow: none;
  }
  .archive-map {
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(0, 1.3fr);
    gap: 1rem;
    margin-bottom: 1rem;
    padding: 1rem;
    box-shadow: none;
  }
  .archive-map strong {
    display: block;
    margin-bottom: 0.45rem;
    color: var(--accent-text);
    font: 0.65rem var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .archive-map p {
    margin: 0;
    color: var(--muted-foreground);
    font-size: 0.82rem;
  }
  .archive-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .empty-state {
    margin: 0;
    padding: 2rem;
    border: 1px dashed var(--border);
    background: var(--card);
    color: var(--muted-foreground);
    font: 0.8rem var(--font-mono);
  }
  @media (max-width: 560px) {
    .collection-summary,
    .archive-map {
      grid-template-columns: 1fr;
      flex-direction: column;
    }
  }
</style>
