---
import BentoCard from '../../components/astro/BentoCard.astro';
import ConsoleShell from '../../components/astro/ConsoleShell.astro';
import SectionHeader from '../../components/astro/SectionHeader.astro';
import Tag from '../../components/astro/Tag.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/console/login');

const description =
  'Private control panel for angefolio Now Status and project records.';
---

<ConsoleShell
  title="Console — Angellie Marcos"
  {description}
  active="overview"
  {user}
>
  <SectionHeader
    eyebrow="Private control panel"
    title="Console overview"
    description="A guarded owner workspace for the current status and database-backed project records."
    headingLevel={1}
  />

  <div class="console-grid">
    <BentoCard
      accent="yellow"
      eyebrow="Available"
      title="Now Status"
      description="Update the focus list shown on the public homepage, with an explicit publish switch and a static fallback."
    >
      <div class="card-footer">
        <Tag tone="green">Protected</Tag>
        <a href="/console/now">Open editor →</a>
      </div>
    </BentoCard>

    <BentoCard
      accent="cyan"
      eyebrow="Available"
      title="Projects Manager"
      description="Create and maintain project metadata, visibility, featured priority, links, and archive state."
    >
      <div class="card-footer">
        <Tag tone="green">Protected</Tag>
        <a href="/console/projects">Manage projects →</a>
      </div>
    </BentoCard>

    <BentoCard
      accent="neutral"
      eyebrow="Planned"
      title="Content management"
      description="Notes, lab entries, stack groups, homepage cards, and settings remain file-based or unimplemented."
    >
      <p class="quiet">Phase 12 does not add any other editing surface.</p>
    </BentoCard>
  </div>
</ConsoleShell>

<style>
  .console-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }
  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .card-footer a {
    color: var(--accent-cyan);
    font: 0.72rem var(--font-mono);
  }
  .quiet {
    margin: 1.25rem 0 0;
    color: var(--muted-foreground);
    font-size: 0.82rem;
  }
  @media (max-width: 720px) {
    .console-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
