---
import BentoCard from '../../components/astro/BentoCard.astro';
import BrandLogo from '../../components/astro/BrandLogo.astro';
import Layout from '../../components/astro/Layout.astro';

const errors: Record<string, string> = {
  invalid: 'Email or password was not accepted.',
  unavailable:
    'Console services are unavailable. Check the server configuration.',
};
const error = Astro.url.searchParams.get('error');
const message = error ? errors[error] : undefined;
const description = 'Private sign-in for the angefolio console.';
---

<Layout
  title="Console login — Angellie Marcos"
  {description}
  noindex
  searchable={false}
  showPageRail={false}
  class="console-login"
>
  <BrandLogo href="/" class="login-logo" priority />

  <BentoCard class="login-card subtle-grid" accent="strong">
    <p class="eyebrow">/console/login</p>
    <h1>Private console</h1>
    <p class="intro">
      Sign in with the single administrator account. Public registration is
      disabled.
    </p>

    {
      message && (
        <p class="form-message" role="alert">
          {message}
        </p>
      )
    }

    <form action="/api/console/login" method="post">
      <label>
        <span>Email</span>
        <input
          type="email"
          name="email"
          autocomplete="username"
          maxlength="254"
          required
        />
      </label>
      <label>
        <span>Password</span>
        <input
          type="password"
          name="password"
          autocomplete="current-password"
          minlength="12"
          maxlength="128"
          required
        />
      </label>
      <button type="submit">Sign in</button>
    </form>

    <p class="setup-note">
      No account yet? Use the documented one-time bootstrap command on the
      server. There is no browser sign-up flow.
    </p>
  </BentoCard>
</Layout>

<style>
  :global(.console-login) {
    max-width: 34rem;
  }
  :global(.login-logo) {
    margin-bottom: 1rem;
  }
  :global(.login-card) {
    padding: clamp(1.4rem, 6vw, 2.5rem);
  }
  h1 {
    margin: 0;
    font-size: clamp(2rem, 7vw, 3.25rem);
    letter-spacing: 0.02em;
  }
  .intro,
  .setup-note {
    color: var(--muted-foreground);
  }
  .intro {
    margin: 0.75rem 0 1.5rem;
  }
  form,
  label {
    display: grid;
  }
  form {
    gap: 1rem;
  }
  label {
    gap: 0.4rem;
  }
  label span {
    font: 0.7rem/1.6 var(--font-mono);
  }
  .setup-note {
    font: 0.875rem/1.6 var(--type-body);
  }
  input {
    width: 100%;
    min-height: 2.75rem;
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    outline: none;
    background: var(--muted);
    color: var(--foreground);
  }
  input:focus {
    border-color: var(--border-strong);
  }
  button {
    min-height: 2.75rem;
    border: 1px solid var(--primary-background);
    border-radius: var(--radius-sm);
    background: var(--primary-background);
    color: var(--accent-foreground);
    cursor: pointer;
    font: 600 0.78rem var(--type-ui);
  }
  .form-message {
    padding: 0.7rem 0.8rem;
    border: 1px solid var(--danger);
    background: var(--danger);
    color: var(--danger-foreground);
    font: 0.72rem var(--font-mono);
  }
  .setup-note {
    margin: 1.25rem 0 0;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
</style>
