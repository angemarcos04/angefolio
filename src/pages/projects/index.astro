---
import CardGrid from '../../components/astro/CardGrid.astro';
import CollectionHeader from '../../components/astro/CollectionHeader.astro';
import Layout from '../../components/astro/Layout.astro';
import ProjectCard from '../../components/astro/ProjectCard.astro';
import SectionHeader from '../../components/astro/SectionHeader.astro';
import {
  getProjectSlug,
  getProjectUrl,
  getVisibleProjects,
} from '../../lib/content';
import { getPublicProjectRecords } from '../../lib/server/projects';

const description =
  "Selected systems, prototypes, and experiments I'm building while learning full-stack development, backend workflows, Linux, and AI-assisted tools.";
const databaseProjects = await getPublicProjectRecords();
const collectionProjects = await getVisibleProjects();
const collectionProjectSlugs = new Set(collectionProjects.map(getProjectSlug));
const projects =
  databaseProjects.length > 0
    ? databaseProjects.map((project) => {
        const detailUrl = collectionProjectSlugs.has(project.slug)
          ? `/projects/${project.slug}`
          : undefined;
        return {
          href: detailUrl,
          title: project.title,
          description: project.description,
          status: project.status,
          category: project.category ?? undefined,
          stack: project.stack,
          github: project.github ?? undefined,
          demo: project.demo ?? undefined,
          caseStudy: detailUrl,
          featured: project.featured,
        };
      })
    : collectionProjects.map((project) => ({
        href: getProjectUrl(project),
        title: project.data.title,
        description: project.data.description,
        status: project.data.status,
        category: project.data.category,
        stack: project.data.stack,
        github: project.data.github,
        demo: project.data.demo,
        caseStudy: project.data.caseStudy,
        featured: project.data.featured,
      }));
---

<Layout title="Projects — Angellie Marcos" {description}>
  <CollectionHeader active="projects" />
  <section aria-labelledby="projects-title">
    <SectionHeader
      id="projects-title"
      eyebrow="/projects"
      title="Projects"
      {description}
      headingLevel={1}
      class="page-heading"
    />
    <div class="collection-summary">
      <p>
        Some projects are in progress or planning. I keep unfinished work
        visible when the direction is useful.
      </p>
      <span>{projects.length} visible</span>
    </div>
    {
      projects.length > 0 ? (
        <CardGrid class="collection-grid">
          {projects.map((project) => (
            <ProjectCard
              href={project.href}
              title={project.title}
              description={project.description}
              status={project.status}
              category={project.category}
              stack={project.stack}
              github={project.github}
              demo={project.demo}
              caseStudy={project.caseStudy}
              featured={project.featured}
            />
          ))}
        </CardGrid>
      ) : (
        <p class="empty-state">No visible projects yet.</p>
      )
    }
  </section>
</Layout>

<style>
  :global(.page-heading) {
    margin-bottom: 1rem;
  }
  .collection-summary {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-block: 0.75rem;
    border-block: 1px solid var(--border);
  }
  .collection-summary p {
    margin: 0;
    color: var(--muted-foreground);
    font: 1rem/1.65 var(--type-body);
  }
  .collection-summary p {
    max-width: 64ch;
  }
  .collection-summary span {
    flex: none;
    color: var(--accent-text);
    font: 500 0.72rem/1.5 var(--type-ui);
  }
  :global(.collection-grid .content-card) {
    height: 100%;
    border-radius: var(--radius-md);
    box-shadow: none;
  }
  .empty-state {
    margin: 0;
    padding: 2rem;
    border: 1px dashed var(--border);
    background: var(--card);
    color: var(--muted-foreground);
    font: 1rem/1.65 var(--type-body);
  }
  @media (max-width: 560px) {
    .collection-summary {
      flex-direction: column;
    }
  }
</style>
