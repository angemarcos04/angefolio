---
import CardGrid from '../../components/astro/CardGrid.astro';
import CollectionHeader from '../../components/astro/CollectionHeader.astro';
import LabCard from '../../components/astro/LabCard.astro';
import Layout from '../../components/astro/Layout.astro';
import SectionHeader from '../../components/astro/SectionHeader.astro';
import Tag from '../../components/astro/Tag.astro';
import { getVisibleLabEntries } from '../../lib/content';

export const prerender = true;
import {
  getAllLabCategories,
  getAllLabTags,
  getLabUrl,
  groupLabByStatus,
} from '../../lib/lab';

const description =
  'Small prototypes, UI experiments, terminal setups, AI persona concepts, and unfinished ideas that might become real projects.';
const entries = await getVisibleLabEntries();
const groups = groupLabByStatus(entries);
const categories = getAllLabCategories(entries);
const tags = getAllLabTags(entries);
---

<Layout title="Lab — Angellie Marcos" {description}>
  <CollectionHeader active="lab" />
  <section aria-labelledby="lab-title">
    <SectionHeader
      id="lab-title"
      eyebrow="/lab"
      title="Lab"
      {description}
      headingLevel={1}
      class="page-heading"
    />
    <div class="collection-summary">
      <p>
        This area is intentionally experimental. Entries can be incomplete,
        paused, or weird, but they should still document what was tried and what
        was learned.
      </p>
      <span>{entries.length} visible</span>
    </div>
    {
      entries.length > 0 && (
        <aside class="workshop-map bento-surface" aria-label="Lab archive map">
          <div>
            <strong>Workshop areas</strong>
            <p>{categories.join(', ')}</p>
          </div>
          <div>
            <strong>Current materials</strong>
            <div class="archive-tags">
              {tags.map((tag) => (
                <Tag>{tag}</Tag>
              ))}
            </div>
          </div>
        </aside>
      )
    }
    {
      entries.length > 0 ? (
        <div class="status-groups">
          {groups.map((group) => (
            <section
              class="status-group"
              aria-labelledby={`status-${group.status}`}
            >
              <header>
                <div>
                  <span aria-hidden="true">./</span>
                  <h2 id={`status-${group.status}`}>{group.status}</h2>
                </div>
                <small>{group.entries.length} entries</small>
              </header>
              <CardGrid class="collection-grid">
                {group.entries.map((entry) => (
                  <LabCard
                    href={getLabUrl(entry)}
                    title={entry.data.title}
                    description={entry.data.description}
                    status={entry.data.status}
                    tags={entry.data.tags}
                    date={entry.data.date}
                    category={entry.data.category}
                    tools={entry.data.tools}
                    featured={entry.data.featured}
                  />
                ))}
              </CardGrid>
            </section>
          ))}
        </div>
      ) : (
        <p class="empty-state">No visible lab entries yet.</p>
      )
    }
  </section>
</Layout>

<style>
  :global(.page-heading) {
    margin-bottom: 1rem;
  }
  .collection-summary {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-block: 0.75rem;
    border-block: 1px solid var(--border);
  }
  .collection-summary p,
  .collection-summary span {
    margin: 0;
    color: var(--muted-foreground);
    font: 0.72rem/1.5 var(--font-mono);
  }
  .collection-summary p {
    max-width: 67ch;
  }
  .collection-summary span {
    flex: none;
    color: var(--accent-text);
  }
  :global(.collection-grid .content-card) {
    height: 100%;
    border-radius: var(--radius-md);
    box-shadow: none;
  }
  .workshop-map {
    display: grid;
    grid-template-columns: minmax(0, 0.75fr) minmax(0, 1.25fr);
    gap: 1rem;
    margin-bottom: 1.75rem;
    padding: 1rem;
    box-shadow: none;
  }
  .workshop-map strong {
    display: block;
    margin-bottom: 0.45rem;
    color: var(--accent-text);
    font: 0.65rem var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .workshop-map p {
    margin: 0;
    color: var(--muted-foreground);
    font-size: 0.82rem;
  }
  .archive-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .status-groups {
    display: grid;
    gap: 2rem;
  }
  .status-group > header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.8rem;
    padding-bottom: 0.55rem;
    border-bottom: 1px solid var(--border);
  }
  .status-group > header div {
    display: flex;
    align-items: baseline;
    gap: 0.1rem;
  }
  .status-group > header span {
    color: var(--accent-text);
    font: 0.78rem var(--font-mono);
  }
  .status-group h2 {
    margin: 0;
    font-size: 1rem;
    letter-spacing: -0.02em;
  }
  .status-group small {
    color: var(--muted-foreground);
    font: 0.65rem var(--font-mono);
  }
  .empty-state {
    margin: 0;
    padding: 2rem;
    border: 1px dashed var(--border);
    background: var(--card);
    color: var(--muted-foreground);
    font: 0.8rem var(--font-mono);
  }
  @media (max-width: 560px) {
    .collection-summary,
    .workshop-map {
      grid-template-columns: 1fr;
      flex-direction: column;
    }
  }
</style>
