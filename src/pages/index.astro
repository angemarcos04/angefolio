---
import BentoCard from '../components/astro/BentoCard.astro';
import BentoGrid from '../components/astro/BentoGrid.astro';
import Button from '../components/astro/Button.astro';
import Layout from '../components/astro/Layout.astro';
import StackGroup from '../components/astro/StackGroup.astro';
import Tag from '../components/astro/Tag.astro';
import TerminalBlock from '../components/astro/TerminalBlock.astro';
import CommandMenuStub from '../components/svelte/CommandMenuStub.svelte';
import ThemeToggle from '../components/svelte/ThemeToggle.svelte';
import { site } from '../lib/data/site';

const stackGroups = [
  { title: 'Core', items: ['Astro', 'Svelte', 'TypeScript'] },
  {
    title: 'Content + UI',
    items: ['Tailwind CSS', 'MDX', 'Content Collections'],
  },
  { title: 'Tooling', items: ['pnpm', 'Docker', 'Linux'] },
];
---

<Layout title={`angefolio — ${site.name}`} description={site.description}>
  <div class="page-top">
    <p class="eyebrow">angefolio / phase 2</p>
    <ThemeToggle client:load />
  </div>

  <BentoGrid>
    <BentoCard
      class="hero subtle-grid md:col-span-2 lg:col-span-8"
      accent="green"
      eyebrow={site.role}
    >
      <h1 class="text-balance">Hi, I’m Angellie Marcos.</h1>
      <p class="tagline">{site.tagline}</p>
      <p class="description">{site.description}</p>
      <div class="actions">
        <Button href="#foundation" variant="primary"
          >Explore the foundation</Button
        >
        <Button href={site.github} external>GitHub</Button>
      </div>
    </BentoCard>

    <BentoCard
      class="md:col-span-2 lg:col-span-4"
      accent="purple"
      eyebrow="About"
      title="Practical systems, personal software."
    >
      <p class="copy">
        I’m an IT student from the Philippines focused on full-stack
        development, backend systems, Linux workflows, and useful experiments.
      </p>
      <div class="tags">
        <Tag tone="green">Full stack</Tag><Tag tone="cyan">Linux</Tag><Tag
          tone="purple">AI + data</Tag
        >
      </div>
    </BentoCard>

    <BentoCard
      id="foundation"
      class="md:col-span-2 lg:col-span-7"
      accent="cyan"
      eyebrow="Stack Preview"
      title="A focused Astro-first foundation."
    >
      <div class="stack-groups">
        {
          stackGroups.map((group) => (
            <StackGroup title={group.title} items={group.items} />
          ))
        }
      </div>
    </BentoCard>

    <BentoCard
      class="lg:col-span-5"
      accent="yellow"
      eyebrow="Phase Status"
      title="Small, reusable, ready to grow."
    >
      <TerminalBlock title="phase-status.sh">
        <p><code>phase --current</code></p>
        <p>
          Phase 2: design tokens, layout primitives, content cards, accessible
          controls, and responsive grids.
        </p>
      </TerminalBlock>
    </BentoCard>

    <BentoCard
      class="md:col-span-2 lg:col-span-12"
      accent="neutral"
      eyebrow="Design System Preview"
      title="Quiet developer tooling, not dashboard theater."
      description="A small preview of the reusable controls and status language that future project, note, and lab pages will share."
    >
      <div class="preview">
        <div class="tags">
          <Tag>Static-first</Tag><Tag tone="green">In Progress</Tag><Tag
            tone="cyan">Prototype</Tag
          ><Tag tone="yellow">Paused</Tag>
        </div>
        <CommandMenuStub />
      </div>
    </BentoCard>
  </BentoGrid>
</Layout>

<style>
  .page-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .page-top .eyebrow {
    margin: 0;
  }
  :global(.hero) {
    min-height: clamp(24rem, 48vw, 34rem);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  h1 {
    max-width: 48rem;
    margin: 0 0 0.8rem;
    font-size: clamp(2.7rem, 8vw, 5.8rem);
    line-height: 0.92;
    letter-spacing: -0.065em;
  }
  .tagline {
    max-width: 42rem;
    margin: 0;
    color: var(--accent-green);
    font-size: clamp(1rem, 2vw, 1.25rem);
  }
  .description,
  .copy {
    color: var(--muted-foreground);
  }
  .description {
    max-width: 47rem;
    margin: 0.7rem 0 1.2rem;
  }
  .copy {
    margin: 0 0 1rem;
  }
  .actions,
  .tags,
  .preview {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }
  .stack-groups {
    display: grid;
    gap: 1.2rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .preview {
    align-items: center;
    justify-content: space-between;
  }
  @media (max-width: 700px) {
    .stack-groups {
      grid-template-columns: 1fr;
    }
    .preview {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
