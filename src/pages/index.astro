---
import { getCollection } from 'astro:content';
import BentoCard from '../components/astro/BentoCard.astro';
import BentoGrid from '../components/astro/BentoGrid.astro';
import BrandLogo from '../components/astro/BrandLogo.astro';
import Button from '../components/astro/Button.astro';
import IconLink from '../components/astro/IconLink.astro';
import Layout from '../components/astro/Layout.astro';
import NoteCard from '../components/astro/NoteCard.astro';
import ProjectCard from '../components/astro/ProjectCard.astro';
import StackGroup from '../components/astro/StackGroup.astro';
import Tag from '../components/astro/Tag.astro';
import TerminalBlock from '../components/astro/TerminalBlock.astro';
import HomeProgressRail from '../components/svelte/HomeProgressRail.svelte';
import ThemeToggle from '../components/svelte/ThemeToggle.svelte';
import {
  aboutTags,
  activityLevels,
  contactLinks,
  nowItems,
  stackGroups,
} from '../lib/data/home';
import { site } from '../lib/data/site';
import { homeProgressSections } from '../lib/data/homeProgress';
import { getProjectSlug, getProjectUrl, sortProjects } from '../lib/content';
import { getNoteUrl, sortNotesByDateDesc } from '../lib/notes';
import { getPublicNowStatus } from '../lib/server/now';
import { getPublicProjectRecords } from '../lib/server/projects';

const databaseProjects = await getPublicProjectRecords();
const collectionProjects = sortProjects(
  await getCollection('projects', ({ data }) => data.visible),
);
const collectionProjectSlugs = new Set(collectionProjects.map(getProjectSlug));
const projects =
  databaseProjects.length > 0
    ? databaseProjects.slice(0, 4).map((project) => {
        const detailUrl = collectionProjectSlugs.has(project.slug)
          ? `/projects/${project.slug}`
          : undefined;
        return {
          href: detailUrl,
          title: project.title,
          description: project.description,
          status: project.status,
          stack: project.stack,
          github: project.github ?? undefined,
          demo: project.demo ?? undefined,
          caseStudy: detailUrl,
          category: project.category ?? undefined,
          featured: project.featured,
        };
      })
    : collectionProjects.slice(0, 4).map((project) => ({
        href: getProjectUrl(project),
        title: project.data.title,
        description: project.data.description,
        status: project.data.status,
        stack: project.data.stack,
        github: project.data.github,
        demo: project.data.demo,
        caseStudy: project.data.caseStudy,
        category: project.data.category,
        featured: project.data.featured,
      }));
const notes = sortNotesByDateDesc(
  await getCollection('notes', ({ data }) => data.published),
).slice(0, 3);
const publicNowStatus = await getPublicNowStatus();
const renderedNowItems = publicNowStatus?.items ?? nowItems;
const nowMetadata = publicNowStatus
  ? (publicNowStatus.statusNote ??
    `Updated ${publicNowStatus.updatedAt.toLocaleDateString('en', {
      dateStyle: 'medium',
    })}.`)
  : 'Static fallback.';
const navItems = [
  { label: 'Projects', href: '/projects' },
  { label: 'Notes', href: '/notes' },
  { label: 'Lab', href: '/lab' },
  { label: 'Search', href: '/search' },
];
---

<Layout title={site.defaultTitle} description={site.seoDescription}>
  <HomeProgressRail client:load sections={homeProgressSections} />
  <header class="topbar" data-pagefind-ignore>
    <BrandLogo href="/" placement="header" priority />
    <div class="topbar-actions">
      <nav aria-label="Primary navigation">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
      <ThemeToggle client:load />
    </div>
  </header>
  <BentoGrid class="homepage-grid">
    <BentoCard
      id="introduction"
      class="hero home-anchor subtle-grid md:col-span-2 lg:col-span-8"
      accent="strong"
    >
      <div class="hero-intro">
        <figure class="hero-portrait">
          <div class="hero-portrait-titlebar" aria-hidden="true">
            <span class="hero-portrait-controls">
              <span class="hero-portrait-control"></span>
              <span class="hero-portrait-control"></span>
              <span class="hero-portrait-control"></span>
            </span>
            <span class="hero-portrait-filename">portrait.jpg</span>
          </div>
          <img
            src="/angellie.jpg"
            alt="Angellie Marcos"
            width="1080"
            height="1080"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="hero-portrait-image"
          />
        </figure>

        <div class="hero-copy">
          <p class="hero-eyebrow eyebrow">{site.role}</p>
          <h1 class="hero-heading text-balance">Angellie D. Marcos</h1>
          <p class="role-line">
            <span class="sr-only">
              Roles: IT student, Linux user, System builder, Full-stack dev.
            </span>

            <span class="role-cycle" aria-hidden="true">
              <span class="role role-1">IT student.</span>
              <span class="role role-2">Linux user.</span>
              <span class="role role-3">System builder.</span>
              <span class="role role-4">Full-stack dev.</span>
            </span>
          </p>
          <div class="actions">
            <Button href="/projects" variant="primary">Projects</Button>
            <Button href={'mailto:' + site.email} variant="ghost">Email</Button>
          </div>
        </div>
      </div>
      <TerminalBlock title="whoami" class="hero-terminal">
        <p><code>~/angefolio $ whoami</code></p>
        <p>angellie :: it-student :: linux-user :: system-builder</p>
      </TerminalBlock>
    </BentoCard>

    <BentoCard
      class="about md:col-span-2 lg:col-span-4"
      accent="soft"
      eyebrow="About"
      title="Coding, tinkering, and convincing computers to do my bidding."
    >
      <p>
        She is studying information technology at AMA Computer College and is a
        member of JPCS in the Philippines, where her specialty includes web
        development with an emphasis on back-end, Linux platforms, and the less
        obvious areas of full-stack development.
      </p>
      <p>
        Her projects revolve around developing tools which are pragmatic,
        personalized, and quite unconventional.
      </p>
      <div class="tags">
        {
          aboutTags.map((tag, index) => (
            <Tag
              tone={index === 0 ? 'strong' : index === 4 ? 'accent' : 'neutral'}
            >
              {tag}
            </Tag>
          ))
        }
      </div>
    </BentoCard>
    <BentoCard
      id="featured-projects"
      class="projects home-anchor md:col-span-2 lg:col-span-12"
      accent="strong"
      eyebrow="Featured Projects"
      title="Systems and ideas I am taking seriously."
      description="A mix of active school systems, prototypes, and planned personal tools."
    >
      <div class="project-grid">
        {
          projects.map((project) => (
            <ProjectCard
              href={project.href}
              title={project.title}
              description={project.description}
              status={project.status}
              stack={project.stack}
              github={project.github}
              demo={project.demo}
              caseStudy={project.caseStudy}
              category={project.category}
              featured={project.featured}
            />
          ))
        }
      </div>
      <div class="card-footer">
        <IconLink href="/projects" label="View all projects" />
      </div>
    </BentoCard>
    <BentoCard
      id="current-focus"
      class="now home-anchor md:col-span-1 lg:col-span-3"
      accent="medium"
      eyebrow="Now"
      title="Current focus"
    >
      <ul class="status-list">
        {renderedNowItems.map((item) => <li>{item}</li>)}
      </ul>
      <p class="metadata">{nowMetadata}</p>
    </BentoCard>

    <BentoCard
      class="stack md:col-span-1 lg:col-span-5"
      accent="soft"
      eyebrow="Stack"
      title="Tools I build with"
    >
      <div class="stack-groups">
        {
          stackGroups.map((group) => (
            <StackGroup title={group.title} items={group.items} />
          ))
        }
      </div>
    </BentoCard>

    <BentoCard
      id="github-activity"
      class="github home-anchor md:col-span-2 lg:col-span-4"
      accent="medium"
      eyebrow="GitHub Activity"
      title="Building in public"
    >
      <p>Public work, experiments, and project commits live here.</p>
      <div
        class="contribution-grid"
        aria-label="Decorative contribution activity grid"
      >
        {
          activityLevels.map((level) => (
            <span class={'level-' + level} aria-hidden="true" />
          ))
        }
      </div>
      <div class="activity-meta" aria-label="GitHub profile status">
        <span>repo: angemarcos04</span>
        <span>status: active learner / project builder</span>
      </div>
      <IconLink href={site.github} label="GitHub" external />
    </BentoCard>
    <BentoCard
      id="latest-notes"
      class="notes home-anchor md:col-span-2 lg:col-span-8"
      accent="soft"
      eyebrow="Latest Notes"
      title="Things I am learning out loud"
    >
      <div class="note-grid">
        {
          notes.map((note) => (
            <NoteCard
              href={getNoteUrl(note)}
              title={note.data.title}
              description={note.data.summary ?? note.data.description}
              category={note.data.category}
              tags={note.data.tags}
              createdAt={note.data.createdAt}
              updatedAt={note.data.updatedAt}
              featured={note.data.featured}
            />
          ))
        }
      </div>
      <div class="card-footer">
        <IconLink href="/notes" label="Read notes" />
      </div>
    </BentoCard>

    <BentoCard
      id="contact"
      class="contact home-anchor md:col-span-2 lg:col-span-4"
      accent="strong"
      eyebrow="Contact"
      title="Let us make something useful."
    >
      <p>Want to talk, collaborate, or check my work?</p>
      <div class="contact-links">
        {
          contactLinks.map((link) => (
            <IconLink
              href={link.href}
              label={link.label}
              external={link.external}
            />
          ))
        }
      </div>
      <p class="contact-email">angellie.marcos0104@protonmail.me</p>
    </BentoCard>
  </BentoGrid>
</Layout>
<style>
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--border);
  }
  .topbar-actions,
  nav,
  .actions,
  .tags {
    display: flex;
    align-items: center;
  }
  .topbar-actions {
    gap: 0.8rem;
  }
  nav {
    flex-wrap: wrap;
    gap: 0.2rem;
  }
  nav a {
    padding: 0.45rem 0.55rem;
    color: var(--muted-foreground);
    font: 0.72rem var(--font-mono);
  }
  nav a:hover {
    color: var(--accent-text);
  }
  :global(.homepage-grid) {
    align-items: stretch;
  }
  :global(.hero) {
    display: flex;
    flex-direction: column;
  }
  .hero-intro {
    display: grid;
    grid-template-columns: clamp(10.5rem, 20vw, 13rem) minmax(0, 1fr);
    align-items: start;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  .hero-portrait {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 13rem;
    aspect-ratio: 4 / 5;
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    background: var(--terminal-background);
  }
  .hero-portrait-titlebar {
    display: flex;
    min-height: 1.85rem;
    align-items: center;
    gap: 0.55rem;
    padding-inline: 0.65rem;
    border-bottom: 1px solid var(--border);
    background: var(--terminal-background);
    color: var(--terminal-muted);
  }
  .hero-portrait-controls {
    display: inline-flex;
    flex: none;
    gap: 0.3rem;
  }
  .hero-portrait-control {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: color-mix(
      in srgb,
      var(--accent) 25%,
      var(--terminal-background)
    );
  }
  .hero-portrait-control:nth-child(2) {
    background: var(--accent);
    opacity: 0.75;
  }
  .hero-portrait-control:nth-child(3) {
    background: var(--terminal-accent);
    opacity: 0.5;
  }
  .hero-portrait-filename {
    min-width: 0;
    overflow: hidden;
    color: var(--terminal-muted);
    font: 500 0.66rem var(--type-code);
    letter-spacing: 0.04em;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .hero-portrait-image {
    display: block;
    width: 100%;
    min-height: 0;
    flex: 1;
    object-fit: cover;
    object-position: center;
  }
  .hero-copy {
    min-width: 0;
  }
  .hero-eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
  }
  .hero-heading {
    max-width: 18ch;
    margin: 0 0 0.85rem;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    line-height: 1.15;
    letter-spacing: 0.01em;
  }
  :global(.home-anchor) {
    scroll-margin-top: clamp(1.5rem, 4vw, 3rem);
  }
  .role-line {
    min-height: 1.4em;
    margin: 0.45rem 0 0;
    color: var(--accent);
    font-family: var(--type-ui);
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    font-weight: 600;
    line-height: 1.4;
    font-variant-ligatures: none;
    font-feature-settings:
      'calt' 0,
      'liga' 0;
  }
  .role-cycle {
    position: relative;
    display: inline-block;
    inline-size: 16ch;
    height: 1.4em;
    vertical-align: bottom;
    white-space: nowrap;
  }
  .role {
    position: absolute;
    inset: 0 auto auto 0;
    opacity: 0;
    white-space: nowrap;
    animation: role-fade 8.8s ease-in-out infinite both;
  }
  .role-1 {
    animation-delay: 0s;
  }
  .role-2 {
    animation-delay: 2.2s;
  }
  .role-3 {
    animation-delay: 4.4s;
  }
  .role-4 {
    animation-delay: 6.6s;
  }
  .about p,
  .github > p,
  .contact > p {
    color: var(--muted-foreground);
  }
  .actions,
  .tags {
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .actions {
    margin-top: 1.2rem;
  }
  :global(.hero-terminal) {
    margin-top: 1.35rem;
  }
  .about p {
    margin: 0 0 0.85rem;
  }
  .about .tags {
    margin-top: 1.15rem;
  }
  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }
  :global(.project-grid .content-card),
  :global(.note-grid .content-card) {
    border-radius: var(--radius-md);
    box-shadow: none;
  }
  .card-footer {
    display: flex;
    justify-content: flex-end;
    margin-top: 1rem;
    padding-top: 0.85rem;
    border-top: 1px solid var(--border);
  }
  .status-list {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .status-list li {
    position: relative;
    padding-left: 1rem;
    color: var(--muted-foreground);
    font-size: 0.86rem;
  }
  .status-list li::before {
    position: absolute;
    top: 0.65em;
    left: 0;
    width: 0.35rem;
    height: 1px;
    background: var(--accent);
    content: '';
  }
  .metadata,
  .activity-meta,
  .contact-email {
    color: var(--muted-foreground);
    font: 0.65rem var(--font-mono);
  }
  .metadata {
    margin: 1.25rem 0 0;
  }
  .stack-groups {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.2rem 1rem;
  }
  .contribution-grid {
    display: grid;
    grid-template-columns: repeat(14, minmax(0, 1fr));
    gap: 0.25rem;
    max-width: 100%;
    margin: 1.1rem 0;
  }
  .contribution-grid span {
    aspect-ratio: 1;
    min-width: 0;
    border: 1px solid color-mix(in srgb, var(--border) 75%, transparent);
    border-radius: 2px;
    background: var(--muted);
  }
  .contribution-grid .level-1 {
    background: color-mix(in srgb, var(--accent) 18%, var(--muted));
  }
  .contribution-grid .level-2 {
    background: color-mix(in srgb, var(--accent) 35%, var(--muted));
  }
  .contribution-grid .level-3 {
    background: color-mix(in srgb, var(--accent) 58%, var(--muted));
  }
  .contribution-grid .level-4 {
    background: color-mix(in srgb, var(--accent) 82%, var(--muted));
  }
  .activity-meta {
    display: grid;
    gap: 0.25rem;
    margin-bottom: 1rem;
  }
  .note-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
  }
  .contact-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 1.4rem 0;
  }
  .contact-email {
    overflow-wrap: anywhere;
  }
  @keyframes role-fade {
    0%,
    3% {
      opacity: 0;
    }

    7%,
    20% {
      opacity: 1;
    }

    24%,
    100% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .role {
      animation: none;
      opacity: 0;
    }

    .role:first-child {
      opacity: 1;
    }
  }
  @media (min-width: 1120px) {
    .project-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
  @media (max-width: 760px) {
    .topbar {
      align-items: flex-start;
    }
    .topbar-actions {
      align-items: flex-end;
      flex-direction: column-reverse;
      gap: 0.45rem;
    }
    :global(.hero) {
      min-height: 0;
    }
    .hero-intro {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .hero-copy {
      order: -1;
    }
    .hero-portrait {
      width: min(13rem, 58vw);
      justify-self: start;
    }
    .project-grid,
    .note-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 480px) {
    .topbar {
      align-items: stretch;
      flex-direction: column;
    }
    .topbar-actions {
      align-items: center;
      flex-wrap: wrap;
      justify-content: space-between;
      flex-direction: row;
    }
    nav a {
      padding-inline: 0.4rem;
    }
    .stack-groups,
    .contact-links {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 420px) {
    .hero-portrait {
      width: min(11rem, 58vw);
    }
  }
</style>
