# Phase 9 requires no environment variables or secrets.
#
# The public site is generated at build time. Its documented placeholder origin
# is configured in astro.config.mjs and src/lib/data/site.ts; update both before
# a real deployment. Runtime database, authentication, and API variables are
# intentionally reserved for a future private /console architecture.

# Future /console variables — not used or required in Phase 10
# AUTH_SECRET=
# DATABASE_URL=
# PUBLIC_SITE_URL=
