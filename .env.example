# Runtime
NODE_ENV=development

# Public origin used by Better Auth. Keep this aligned with the deployed site.
PUBLIC_SITE_URL=http://localhost:4321
AUTH_TRUSTED_ORIGIN=http://localhost:4321

# Server-only authentication secret. Generate at least 32 random characters.
# Never expose this as a PUBLIC_ variable or commit a real value.
AUTH_SECRET=

# Local SQLite through libSQL. Docker overrides this with file:/app/data/angefolio.db.
DATABASE_URL=file:./data/angefolio.db

# One-time bootstrap inputs. Set only while running `pnpm console:bootstrap`,
# then remove them. They are not read by the web application.
ADMIN_EMAIL=
ADMIN_PASSWORD=
